# ===========================================
# Node Environment
# ===========================================
NODE_ENV=development

# ===========================================
# Application Configuration
# ===========================================
PORT=5000

# Enable CORS for frontend (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# GraphQL Playground (set to true for development)
GRAPHQL_PLAYGROUND=true

# Logging Level (error, warn, info, debug)
LOG_LEVEL=info

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/floventry

# Synchronize database schema automatically (NEVER set to true in production!)
DB_SYNCHRONIZE=true

# ===========================================
# Authentication - Clerk
# ===========================================
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# ===========================================
# JWT Configuration
# ===========================================
# Minimum 32 characters required
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_long

# ===========================================
# Redis Configuration (for caching)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Alternative: Use complete Redis URL instead of individual settings
# REDIS_URL=redis://username:password@localhost:6379/0

# ===========================================
# AWS S3 Configuration (for file uploads)
# ===========================================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your_s3_bucket_name

# ===========================================
# Email Configuration (Nodemailer)
# ===========================================
# SMTP Server Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Sender Email Address
EMAIL_FROM=Floventry <noreply@floventry.com>

# Alternative SMTP Configuration (will override EMAIL_* if set)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-specific-password

# ===========================================
# Frontend Configuration
# ===========================================
# Used for generating invite links and other frontend URLs
FRONTEND_URL=http://localhost:3000
